@model IEnumerable<AspNetAuthSystem.Models.User>

@{
    ViewData["Title"] = "Manage Teachers";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>👨‍🏫 Manage Teachers</h2>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="CreateTeacher" class="btn btn-success">➕ Add New Teacher</a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Username</th>
                        <th>Email</th>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>Created Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var teacher in Model)
                    {
                        <tr>
                            <td>@teacher.UserName</td>
                            <td>@teacher.Email</td>
                            <td>@teacher.FirstName</td>
                            <td>@teacher.LastName</td>
                            <td>@teacher.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (teacher.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td>
                                <form asp-action="DeleteTeacher" asp-route-id="@teacher.Id" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this teacher?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">🗑️ Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No teachers found. <a asp-action="CreateTeacher" class="alert-link">Create one now</a>.
        </div>
    }
</div>
