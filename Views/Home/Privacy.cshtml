@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <h1>📋 Privacy Policy</h1>
            <hr />

            <h3>Introduction</h3>
            <p>Welcome to ASP.NET Core Authentication System. We are committed to protecting your privacy and ensuring you have a positive experience on our platform.</p>

            <h3>Information We Collect</h3>
            <ul>
                <li><strong>Personal Information:</strong> Name, email address, username, and other registration details.</li>
                <li><strong>Usage Data:</strong> Information about how you interact with our platform.</li>
                <li><strong>Technical Data:</strong> IP address, browser type, and device information.</li>
            </ul>

            <h3>How We Use Your Information</h3>
            <ul>
                <li>To create and manage your account</li>
                <li>To provide course management services</li>
                <li>To send important notifications and updates</li>
                <li>To improve our services and user experience</li>
            </ul>

            <h3>Security</h3>
            <p>We implement security measures to protect your personal information, including password hashing and secure authentication protocols.</p>

            <h3>Contact Us</h3>
            <p>If you have any questions about this privacy policy, please contact us through our support channels.</p>

            <hr />
            <p class="text-muted">Last updated: @DateTime.Now.Year</p>
        </div>
    </div>
</div>
