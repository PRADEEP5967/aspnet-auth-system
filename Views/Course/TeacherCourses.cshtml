@model List<AspNetAuthSystem.DTOs.CourseDTO>

@{
    ViewData["Title"] = "My Courses";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>📚 My Courses</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create", "Course")" class="btn btn-success">➕ Create New Course</a>
        </div>
    </div>

    @if (Model?.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover shadow">
                <thead class="table-dark">
                    <tr>
                        <th>📖 Title</th>
                        <th>📝 Description</th>
                        <th>📅 Created</th>
                        <th>⚙️ Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td><strong>@course.Title</strong></td>
                            <td>@(course.Description.Length > 40 ? course.Description.Substring(0, 40) + "..." : course.Description)</td>
                            <td>@course.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                <a href="@Url.Action("Edit", "Course", new { id = course.Id })" class="btn btn-sm btn-warning">✏️ Edit</a>
                                <form method="post" asp-action="Delete" asp-route-id="@course.Id" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this course?')">🗑️ Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <h4 class="alert-heading">📭 No Courses Yet</h4>
            <p>You haven't created any courses yet. <a href="@Url.Action("Create", "Course")" class="alert-link">Create your first course</a>!</p>
        </div>
    }
</div>
