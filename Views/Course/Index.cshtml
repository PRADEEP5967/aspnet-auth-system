@model List<AspNetAuthSystem.DTOs.CourseDTO>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>📚 Available Courses</h2>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Teacher"))
            {
                <a href="@Url.Action("Create", "Course")" class="btn btn-success">➕ Create New Course</a>
            }
        </div>
    </div>

    @if (Model?.Count > 0)
    {
        <div class="row">
            @foreach (var course in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow">
                        <div class="card-body">
                            <h5 class="card-title">@course.Title</h5>
                            <p class="card-text text-muted">@(course.Description.Length > 100 ? course.Description.Substring(0, 100) + "..." : course.Description)</p>
                            <p class="card-text">
                                <small class="text-muted">
                                    <strong>👨‍🏫 Teacher:</strong> @course.TeacherName<br />
                                    <strong>📅 Created:</strong> @course.CreatedAt.ToString("yyyy-MM-dd")
                                </small>
                            </p>
                        </div>
                        <div class="card-footer bg-white">
                            <a href="@Url.Action("Details", "Course", new { id = course.Id })" class="btn btn-sm btn-primary">👁️ View Details</a>
                            @if (User.IsInRole("Student"))
                            {
                                <a href="@Url.Action("Enroll", "Course", new { id = course.Id })" class="btn btn-sm btn-success">✏️ Enroll</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <h4 class="alert-heading">📭 No Courses Available</h4>
            <p>There are currently no courses available. Check back later!</p>
        </div>
    }
</div>
