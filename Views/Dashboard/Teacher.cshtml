@{
    ViewData["Title"] = "Teacher Dashboard";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="alert alert-success" role="alert">
                <h4 class="alert-heading">👨‍🏫 Welcome to Teacher Dashboard</h4>
                <p class="mb-0">Manage your courses and interact with students.</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">📚 My Courses</h5>
                    <p class="card-text">View and manage all your courses.</p>
                    <a href="@Url.Action("TeacherCourses", "Course")" class="btn btn-success">📖 View Courses</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">➕ Create Course</h5>
                    <p class="card-text">Create a new course for your students.</p>
                    <a href="@Url.Action("Create", "Course")" class="btn btn-success">🆕 Create</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">👨‍🎓 Students</h5>
                    <p class="card-text">View enrolled students and their progress.</p>
                    <button class="btn btn-info" disabled>🔍 Coming Soon</button>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">📊 Quick Stats</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Total Courses Created:</strong> <span class="badge bg-primary">-</span></p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Total Students Enrolled:</strong> <span class="badge bg-info">-</span></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="@Url.Action("Profile", "Dashboard")" class="btn btn-secondary">👤 View Profile</a>
    </div>
</div>
